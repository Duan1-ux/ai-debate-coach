APP_NAME=ai-debate-coach-backend
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///storage/debate_coach.db
TEST_DATABASE_URL=sqlite:///:memory:

MAX_DEBATE_ROUNDS=3
PROMPT_HISTORY_LIMIT=6
MOCK_STREAM_CHUNK_SIZE=24

LLM_PROVIDER=mock
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
